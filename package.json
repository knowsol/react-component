{
    "name": "react-component",
    "private": true,
    "version": "0.0.10",
    "description": "Reusable React components for internal applications",
    "type": "module",
    "main": "./dist-lib/index.js",
    "module": "./dist-lib/index.js",
    "exports": {
        ".": {
            "import": "./dist-lib/index.js"
        }
    },
    "files": [
        "dist-lib",
        "README.md"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:lib": "vite build --config vite.lib.config.js",
        "prepare": "npm run build:lib",
        "pack:local": "npm pack",
        "lint": "eslint .",
        "preview": "vite preview"
    },
    "dependencies": {
        "air-datepicker": "^3.6.0"
    },
    "peerDependencies": {
        "react": ">=18 <20",
        "react-dom": ">=18 <20",
        "react-router-dom": ">=6 <8",
        "styled-components": ">=6 <7"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.17.0",
        "styled-components": "^6.4.2",
        "vite": "^8.0.10"
    }
}
